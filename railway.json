{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "install": {
          "pkgs": ["nodejs_20"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node --import tsx server/_core/index.ts",
    "restartPolicyType": "ON_FAILURE"
  },
  "ports": [
    {
      "port": 8080,
      "type": "http"
    }
  ]
}
